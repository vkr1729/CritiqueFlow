# === LLM Configuration ===
# Primary: Google AI Studio (free, OpenAI-compatible)
#   Endpoint: https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#   Get key: https://aistudio.google.com/apikey
# Fallback: Groq (free, OpenAI-compatible)
#   Endpoint: https://api.groq.com/openai/v1/chat/completions
#   Get key: https://console.groq.com
# Production: Corporate gateway
#   Endpoint: https://YOUR_INTERNAL_HOST/invoke

LLM_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_TOP_K=40
LLM_MAX_TOKENS=8192

# === Harness Behavior ===
MAX_ITERATION_DEPTH=3
EARLY_STOP_CONFIDENCE=0.85

# === Server ===
HOST=127.0.0.1
PORT=5000

# === Security ===
ALLOWED_OUTBOUND_HOSTS=generativelanguage.googleapis.com
KILL_ON_VIOLATION=true
ENABLE_NETWORK_GUARD=true

# === File Reader Caps ===
# 0 = unlimited, -1 = use default (50000 chars / 100 rows)
FILE_CHAR_CAP=50000
FILE_ROW_CAP=100

# === Session Management ===
MAX_SESSION_HISTORY=100
